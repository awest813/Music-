FROM node:22-alpine AS build
WORKDIR /app
RUN corepack enable
COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @nuclearplayer/server build

FROM node:22-alpine
WORKDIR /app
RUN apk add --no-cache python3 py3-pip ffmpeg && pip install --break-system-packages yt-dlp
COPY --from=build /app/packages/server/dist ./dist
COPY --from=build /app/packages/server/package.json ./package.json
ENV PORT=3473
EXPOSE 3473
CMD ["node", "dist/index.js"]
