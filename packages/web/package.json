{
  "name": "@nuclearplayer/web",
  "version": "0.0.10",
  "description": "Browser web app for Nuclear",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "test:coverage": "vitest --run --coverage --passWithNoTests",
    "clean": "rm -rf dist build .turbo node_modules/.vite"
  },
  "dependencies": {
    "@nuclearplayer/hifi": "workspace:*",
    "@nuclearplayer/i18n": "workspace:*",
    "@nuclearplayer/model": "workspace:*",
    "@nuclearplayer/platform": "workspace:*",
    "@nuclearplayer/plugin-sdk": "workspace:*",
    "@nuclearplayer/tailwind-config": "workspace:*",
    "@nuclearplayer/themes": "workspace:*",
    "@nuclearplayer/ui": "workspace:*",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-router": "^1.131.2",
    "immer": "^11.1.4",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.542.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@nuclearplayer/eslint-config": "workspace:*",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/router-vite-plugin": "^1.166.12",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/coverage-v8": "^4.0.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^4.0.0"
  }
}
