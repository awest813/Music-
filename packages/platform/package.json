{
  "name": "@nuclearplayer/platform",
  "version": "0.0.10",
  "description": "Shared platform abstraction for Nuclear desktop and web runtimes",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./dist/index.d.ts"
    },
    "./tauri": {
      "import": "./src/tauri.ts",
      "types": "./dist/tauri.d.ts"
    },
    "./web": {
      "import": "./src/web.ts",
      "types": "./dist/web.d.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist build .turbo node_modules/.vite"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-fs": "~2.4.1",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "~2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "~2.4.0",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@nuclearplayer/eslint-config": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.23",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.0"
  }
}
